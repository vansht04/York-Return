{
  "entities": {
    "Item": {
      "title": "Item",
      "description": "A lost or found item report",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["lost", "found"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] },
        "reportedBy": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterPhone": { "type": "string" },
        "reporterEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "location", "status", "reportedBy"]
    }
  },
  "firestore": {
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Collection of lost and found items"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Community feedback for the platform"
    }
  }
}
